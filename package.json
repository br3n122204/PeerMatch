{
  "name": "peer-match",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:clean && concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:clean": "npx kill-port 3000 5000 5174",
    "dev:next": "next dev",
    "dev:server": "nodemon server/server.js",
    "dev:admin": "npm run dev --prefix frontends/admin",
    "build": "next build",
    "start": "next start",
    "start:server": "node server/server.js",
    "seed:admin": "node server/seedAdmin.js",
    "lint": "eslint"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.472.0",
    "mongodb": "^7.1.1",
    "mongoose": "^7.8.9",
    "next": "16.2.1",
    "nodemailer": "^6.9.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
